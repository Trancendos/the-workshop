# ============================================================
# the-workshop — Environment Configuration
# 2060 Modular Standard · Trancendos Ecosystem
# ============================================================

# Server
PORT=3013
NODE_ENV=development
LOG_LEVEL=info

# IAM (required for production)
IAM_JWT_SECRET=your-hs512-secret-min-64-chars-change-in-production
IAM_URL=http://localhost:8000

# 2060 Mesh Routing
MESH_ADDRESS=workshop.agent.local
MESH_ROUTING_PROTOCOL=static_port

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Service Discovery
INFINITY_PORTAL_URL=http://localhost:8000
CORNELIUS_URL=http://localhost:3001
GUARDIAN_URL=http://localhost:3002
